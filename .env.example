# Copy to .env and fill in values before running
# All vars are prefixed SENTINEL_ and read by pydantic-settings

# Auth — change this before any customer-facing deployment
SENTINEL_API_KEY=dev-key-123

# Redis (set automatically by docker-compose)
SENTINEL_REDIS_URL=redis://localhost:6379/0

# Celery (set automatically by docker-compose)
SENTINEL_CELERY_BROKER_URL=redis://localhost:6379/1
SENTINEL_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# PostgreSQL (set automatically by docker-compose)
SENTINEL_POSTGRES_URL=postgresql+asyncpg://sentinel:sentinel@localhost/sentinelmcp

# SIEM webhooks (optional — leave blank to disable)
SENTINEL_SPLUNK_HEC_URL=
SENTINEL_SPLUNK_HEC_TOKEN=
SENTINEL_DATADOG_API_KEY=
SENTINEL_WEBHOOK_URL=
