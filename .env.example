# Copy to .env and fill in real values. Never commit .env to git.

# API authentication
SENTINEL_API_KEY=sk-change-me-in-production

# Redis (password enforced — do not leave blank in production)
SENTINEL_REDIS_PASSWORD=change-me-redis-password

# Postgres
SENTINEL_POSTGRES_PASSWORD=change-me-postgres-password

# Allowlist enforcement (set true to block unknown MCP servers)
SENTINEL_ALLOWLIST_ENABLED=false

# SIEM integrations (optional)
SENTINEL_SPLUNK_HEC_URL=
SENTINEL_SPLUNK_HEC_TOKEN=
SENTINEL_DATADOG_API_KEY=
SENTINEL_WEBHOOK_URL=

# Ollama (for local LLM demo agent)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
