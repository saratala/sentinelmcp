{
  "title": "SentinelMCP — Threat Dashboard",
  "uid": "sentinelmcp-threats",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["sentinelmcp", "security"],
  "panels": [
    {
      "id": 1,
      "title": "Total Threats (Last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": 0 }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT COUNT(*) AS value FROM threat_events WHERE timestamp > now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Block Rate %",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN blocked THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS value FROM threat_events WHERE timestamp > now() - interval '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Sessions (Last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT COUNT(DISTINCT session_id) AS value FROM threat_events WHERE timestamp > now() - interval '1 hour'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Threats Over Time (7 Days)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, count(*) AS threats FROM threat_events WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "OWASP Breakdown by Threat Type",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT threat_type, count(*) AS count FROM threat_events WHERE $__timeFilter(timestamp) GROUP BY threat_type ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Threats by Layer",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT layer::text AS layer, count(*) AS count FROM threat_events WHERE $__timeFilter(timestamp) GROUP BY layer ORDER BY layer",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Block Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, ROUND(100.0 * SUM(CASE WHEN blocked THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS block_rate FROM threat_events WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent Threats (Last 50)",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "timestamp", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "blocked" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "color": "dark-red", "index": 0, "text": "BLOCKED" } } },
                  { "type": "value", "options": { "false": { "color": "green", "index": 1, "text": "ALLOWED" } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "SentinelMCP" },
          "rawSql": "SELECT timestamp, threat_type, tool_name, layer, blocked, pattern FROM threat_events WHERE $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
